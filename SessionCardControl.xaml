<UserControl
    x:Class="AudioRoute.SessionCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="RoutePickerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="140" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#0AFFFFFF" />
            <Setter Property="BorderBrush" Value="#12FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>
    <Grid Padding="14,10,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: App info header -->
        <Grid Grid.Row="0" ColumnSpacing="10" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="30"
                    Height="30"
                    CornerRadius="6"
                    Background="#12FFFFFF"
                    VerticalAlignment="Center">
                <Grid>
                    <Image x:Name="SessionIconImage"
                           Width="18"
                           Height="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           Visibility="Collapsed" />
                    <FontIcon x:Name="SessionFallbackIcon"
                              FontSize="15"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleTextBlock"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1" />
                <TextBlock x:Name="ProcessTextBlock"
                           FontSize="11"
                           Foreground="#FF9A9A9A"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1" />
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                <Button x:Name="OutputRouteButton"
                        Style="{StaticResource RoutePickerButtonStyle}"
                        Click="OutputRouteButton_Click">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="OutputRouteTextBlock"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                        <FontIcon Grid.Column="1"
                                  Glyph="&#xE70D;"
                                  FontSize="10"
                                  VerticalAlignment="Center" />
                    </Grid>
                </Button>
                <Button x:Name="InputRouteButton"
                        Style="{StaticResource RoutePickerButtonStyle}"
                        Click="InputRouteButton_Click">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="InputRouteTextBlock"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                        <FontIcon Grid.Column="1"
                                  Glyph="&#xE70D;"
                                  FontSize="10"
                                  VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1: Mute + Slider row (Win11 style) -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="MuteButton"
                    Width="30"
                    Height="30"
                    Padding="0"
                    CornerRadius="6"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    Click="MuteButton_Click">
                <FontIcon x:Name="MuteIcon"
                          FontSize="14"
                          Glyph="&#xE767;" />
            </Button>

            <Slider x:Name="VolumeSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="100"
                    StepFrequency="1"
                    SmallChange="1"
                    LargeChange="5"
                    VerticalAlignment="Center"
                    ValueChanged="VolumeSlider_ValueChanged"
                    PointerPressed="VolumeSlider_PointerPressed"
                    PointerReleased="VolumeSlider_PointerReleased"
                    PointerCaptureLost="VolumeSlider_PointerCaptureLost" />
        </Grid>
    </Grid>
</UserControl>
