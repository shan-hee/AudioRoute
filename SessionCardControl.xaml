<UserControl
    x:Class="AudioRoute.SessionCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="14,10,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: App info header -->
        <Grid Grid.Row="0" ColumnSpacing="10" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="30"
                    Height="30"
                    CornerRadius="6"
                    Background="#12FFFFFF"
                    VerticalAlignment="Center">
                <FontIcon x:Name="SessionIcon"
                          FontSize="15"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleTextBlock"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1" />
                <TextBlock x:Name="ProcessTextBlock"
                           FontSize="11"
                           Foreground="#FF9A9A9A"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1" />
            </StackPanel>

            <Border Grid.Column="2"
                    Padding="7,2"
                    Background="#143AA5FF"
                    CornerRadius="4"
                    VerticalAlignment="Center">
                <TextBlock x:Name="VolumeValueTextBlock"
                           Foreground="#FF8FD0FF"
                           FontWeight="SemiBold"
                           FontSize="11" />
            </Border>
        </Grid>

        <!-- Row 1: Mute + Slider row (Win11 style) -->
        <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="MuteButton"
                    Width="30"
                    Height="30"
                    Padding="0"
                    CornerRadius="6"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    Click="MuteButton_Click">
                <FontIcon x:Name="MuteIcon"
                          FontSize="14"
                          Glyph="&#xE767;" />
            </Button>

            <Slider x:Name="VolumeSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="100"
                    StepFrequency="1"
                    SmallChange="1"
                    LargeChange="5"
                    VerticalAlignment="Center"
                    ValueChanged="VolumeSlider_ValueChanged"
                    PointerPressed="VolumeSlider_PointerPressed"
                    PointerReleased="VolumeSlider_PointerReleased"
                    PointerCaptureLost="VolumeSlider_PointerCaptureLost" />
        </Grid>

        <!-- Row 2: Device routing (compact) -->
        <Grid x:Name="DevicePanel" Grid.Row="2" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Current/Target device info in one compact line -->
            <Grid Grid.Row="0" ColumnSpacing="6" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <FontIcon Glyph="&#xE7F5;"
                          FontSize="10"
                          Foreground="#FF777777"
                          VerticalAlignment="Center" />
                <TextBlock x:Name="DeviceInfoTextBlock"
                           Grid.Column="1"
                           FontSize="11"
                           Foreground="#FF888888"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1" />
            </Grid>

            <!-- Device selector dropdown -->
            <ComboBox x:Name="DeviceComboBox"
                      Grid.Row="1"
                      DisplayMemberPath="Title"
                      HorizontalAlignment="Stretch"
                      MaxDropDownHeight="420"
                      FontSize="12"
                      SelectionChanged="DeviceComboBox_SelectionChanged"
                      DropDownOpened="DeviceComboBox_DropDownOpened"
                      DropDownClosed="DeviceComboBox_DropDownClosed" />
        </Grid>
    </Grid>
</UserControl>
