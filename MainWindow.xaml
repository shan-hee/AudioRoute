<Window
    x:Class="AudioRoute.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AudioRoute">
    <Grid x:Name="WindowRoot" Background="Transparent" RequestedTheme="Dark">
        <Grid.Resources>
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FF202020" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF3A3A3A" />
            <SolidColorBrush x:Key="PanelRaisedBrush" Color="#FF2A2A2A" />
            <SolidColorBrush x:Key="PanelMutedBrush" Color="#FFBEBEBE" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FF3AA5FF" />

            <Style x:Key="HeaderIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="34" />
                <Setter Property="Height" Value="34" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="17" />
                <Setter Property="Background" Value="#1AFFFFFF" />
                <Setter Property="BorderBrush" Value="#14FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="FlowButtonStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14,9" />
                <Setter Property="Background" Value="#15000000" />
                <Setter Property="BorderBrush" Value="#18FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>
        </Grid.Resources>

        <Border x:Name="PanelSurface"
                Width="472"
                Height="706"
                Padding="16"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="DismissButton"
                            Grid.Column="0"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="DismissButton_Click">
                        <SymbolIcon Symbol="Back" />
                    </Button>

                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                        <TextBlock Text="Audio mixer"
                                   FontSize="21"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Quick routing and per-app audio control"
                                   Foreground="{StaticResource PanelMutedBrush}"
                                   FontSize="12" />
                    </StackPanel>

                    <Button x:Name="RefreshButton"
                            Grid.Column="2"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="RefreshButton_Click">
                        <FontIcon Glyph="&#xE72C;" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="OutputButton"
                            Grid.Column="0"
                            Style="{StaticResource FlowButtonStyle}"
                            Click="OutputButton_Click"
                            Content="Output" />
                    <Button x:Name="InputButton"
                            Grid.Column="1"
                            Style="{StaticResource FlowButtonStyle}"
                            Click="InputButton_Click"
                            Content="Input" />
                </Grid>

                <Border Grid.Row="2"
                        Padding="14,12"
                        Background="#14000000"
                        CornerRadius="14"
                        BorderBrush="#12FFFFFF"
                        BorderThickness="1">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Overview"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PanelMutedBrush}" />
                        <TextBlock x:Name="SummaryTextBlock"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="MetaTextBlock"
                                   FontSize="12"
                                   Foreground="{StaticResource PanelMutedBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Padding="6"
                        Background="{StaticResource PanelRaisedBrush}"
                        CornerRadius="16"
                        BorderBrush="#12000000"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="SessionHost" Spacing="10" Padding="2" />
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="4"
                        Padding="12,9"
                        Background="#14000000"
                        CornerRadius="12">
                    <TextBlock Text="Press Esc or click outside the panel to dismiss"
                               Foreground="{StaticResource PanelMutedBrush}"
                               FontSize="11" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
